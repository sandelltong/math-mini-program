/* pages/chat/chat.wxss */
.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #FFF5F7 0%, #FFE4E9 100%);
}

/* ========== 顶部操作栏 ========== */
.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: white;
  box-shadow: 0 2rpx 10rpx rgba(255, 182, 193, 0.1);
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.header-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 20rpx;
  background: #FFF0F3;
  border-radius: 30rpx;
}

.action-btn .icon {
  font-size: 28rpx;
}

.action-btn .text {
  font-size: 24rpx;
  color: #FF6B8A;
}

/* ========== 消息列表 ========== */
.message-list {
  flex: 1;
  padding: 30rpx;
  overflow-y: auto;
}

.message-item {
  display: flex;
  margin-bottom: 30rpx;
  align-items: flex-start;
}

.message-item.user {
  flex-direction: row-reverse;
}

.message-item.assistant {
  flex-direction: row;
}

.message-avatar {
  font-size: 50rpx;
  margin: 0 15rpx;
  flex-shrink: 0;
}

/* 系统消息 */
.system-message {
  text-align: center;
  padding: 15rpx 0;
}

.system-message text {
  display: inline-block;
  background: rgba(255, 182, 193, 0.2);
  color: #999;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

/* 消息气泡 */
.message-wrapper {
  display: flex;
  align-items: flex-start;
  max-width: 100%;
}

.message-bubble {
  max-width: 70%;
  padding: 25rpx 30rpx;
  border-radius: 24rpx;
  position: relative;
}

.message-bubble.user {
  background: linear-gradient(135deg, #FFB6C1 0%, #FF9AAF 100%);
  color: white;
  border-bottom-right-radius: 8rpx;
}

.message-bubble.assistant {
  background: white;
  color: #333;
  border-bottom-left-radius: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 182, 193, 0.2);
}

.message-bubble.thinking {
  background: #FFF0F3;
  color: #999;
}

.message-content {
  font-size: 28rpx;
  line-height: 1.6;
  display: block;
  white-space: pre-wrap;
  word-break: break-all;
}

/* 消息底部（时间 + 复制按钮） */
.message-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
}

.message-time {
  font-size: 22rpx;
  opacity: 0.6;
}

.copy-btn {
  font-size: 26rpx;
  padding: 5rpx 10rpx;
  border-radius: 10rpx;
  background: rgba(255, 182, 193, 0.2);
}

.copy-btn:active {
  background: rgba(255, 182, 193, 0.4);
}

/* 思考动画 */
.thinking-animation {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.dots {
  animation: blink 1.4s infinite both;
}

.dots:nth-child(2) {
  animation-delay: 0.2s;
}

.dots:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes blink {
  0% { opacity: 0.2; }
  20% { opacity: 1; }
  100% { opacity: 0.2; }
}

/* ========== 输入区域 ========== */
.input-area {
  background: white;
  padding: 20rpx;
  box-shadow: 0 -4rpx 20rpx rgba(255, 182, 193, 0.15);
}

.quick-questions {
  white-space: nowrap;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
}

.quick-tag {
  display: inline-block;
  background: linear-gradient(135deg, #FFF0F3 0%, #FFE4E9 100%);
  color: #FF6B8A;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  margin-right: 15rpx;
  border: 2rpx solid #FFB6C1;
  transition: all 0.2s;
}

.quick-tag:active {
  background: #FFB6C1;
  color: white;
  transform: scale(0.95);
}

.input-box {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.voice-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background: #FFF0F3;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #FFB6C1;
  transition: all 0.2s;
  flex-shrink: 0;
}

.voice-btn.recording {
  background: #FFB6C1;
  transform: scale(1.1);
  box-shadow: 0 0 20rpx rgba(255, 182, 193, 0.6);
}

.voice-btn .icon {
  font-size: 40rpx;
}

.text-input {
  flex: 1;
  background: #F5F5F5;
  border-radius: 40rpx;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
}

.placeholder-style {
  color: #CCC;
}

.send-btn {
  background: linear-gradient(135deg, #FFB6C1 0%, #FF9AAF 100%);
  color: white;
  padding: 20rpx 35rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  opacity: 0.5;
  transition: all 0.2s;
}

.send-btn.active {
  opacity: 1;
}

.send-btn:active {
  opacity: 0.8;
  transform: scale(0.95);
}
