/* pages/history/history.wxss */
.container {
  padding: 30rpx;
  background: #FFF5F7;
  min-height: 100vh;
}

.card {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 182, 193, 0.15);
}

.header-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: linear-gradient(135deg, #FFB6C1 0%, #FF9AAF 100%);
  color: white;
}

.header-icon {
  font-size: 60rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
}

.header-subtitle {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.stats-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #FF6B8A;
}

.stats-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin: 40rpx 0 20rpx;
}

/* 记录列表 */
.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
}

.history-main {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.history-icon {
  font-size: 40rpx;
  width: 70rpx;
  height: 70rpx;
  background: #FFF0F3;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.history-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.history-title {
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 400rpx;
}

.history-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.history-arrow {
  color: #CCC;
  font-size: 40rpx;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}