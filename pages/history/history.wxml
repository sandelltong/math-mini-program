<!--pages/history/history.wxml - 学习记录页面-->
<view class="container">
  <view class="header-card card">
    <view class="header-icon">📝</view>
    <view class="header-text">
      <text class="header-title">学习记录</text>
      <text class="header-subtitle">记录你的点滴进步~</text>
    </view>
  </view>

  <!-- 统计概览 -->
  <view class="stats-grid">
    <view class="stats-item card">
      <text class="stats-num">{{historyCount}}</text>
      <text class="stats-label">对话次数</text>
    </view>
    <view class="stats-item card">
      <text class="stats-num">{{lastStudyDate || '今天'}}</text>
      <text class="stats-label">最近学习</text>
    </view>
  </view>

  <view class="section-title">🕒 历史足迹</view>

  <!-- 记录列表 -->
  <view class="history-list">
    <view 
      wx:for="{{historyItems}}" 
      wx:key="timestamp"
      class="history-item card"
      bindtap="viewDetail"
      data-item="{{item}}"
    >
      <view class="history-main">
        <view class="history-icon">{{item.type === 'practice' ? '✏️' : '💬'}}</view>
        <view class="history-info">
          <text class="history-title">{{item.userMsg.content}}</text>
          <text class="history-time">{{item.displayTime}}</text>
        </view>
      </view>
      <view class="history-arrow">›</view>
    </view>
    
    <view wx:if="{{historyItems.length === 0}}" class="empty-state">
      <text>还没有记录哦，快去开始学习吧！</text>
    </view>
  </view>
</view>