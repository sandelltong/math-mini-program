<!--pages/topics/topics.wxml - 知识点页面-->
<view class="container">
  <view class="header-card card">
    <view class="header-icon">📖</view>
    <view class="header-text">
      <text class="header-title">知识点学习</text>
      <text class="header-subtitle">按章节系统学习，打好基础~</text>
    </view>
  </view>

  <!-- 年级选择 -->
  <view class="grade-selector">
    <view 
      wx:for="{{grades}}" 
      wx:key="*this"
      class="grade-tag {{currentGrade === item ? 'active' : ''}}"
      bindtap="selectGrade"
      data-grade="{{item}}"
    >
      {{item}}
    </view>
  </view>

  <!-- 知识点列表 -->
  <view class="topic-list">
    <view 
      wx:for="{{filteredTopics}}" 
      wx:key="id"
      class="topic-item card"
      bindtap="goToTopicDetail"
      data-topic="{{item}}"
    >
      <view class="topic-icon">{{topicIcons[index % topicIcons.length]}}</view>
      <view class="topic-info">
        <text class="topic-name">{{item.name}}</text>
        <text class="topic-grade">{{item.grade}}</text>
      </view>
      <view class="topic-arrow">›</view>
    </view>
  </view>
</view>
