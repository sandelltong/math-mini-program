/* app.wxss - 全局样式 */
page {
  background: linear-gradient(180deg, #FFF5F7 0%, #FFE4E9 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', sans-serif;
}

.container {
  padding: 20rpx;
}

/* 温柔粉色主题 */
.btn-primary {
  background: linear-gradient(135deg, #FFB6C1 0%, #FF9AAF 100%);
  color: white;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 20rpx 40rpx;
}

.btn-primary:active {
  opacity: 0.8;
}

.card {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 20rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(255, 182, 193, 0.3);
}

.text-gentle {
  color: #666;
  font-size: 28rpx;
  line-height: 1.8;
}

.text-highlight {
  color: #FF6B8A;
  font-weight: 500;
}
